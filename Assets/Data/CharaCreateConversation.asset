    endActions:
    - actionType: 3
      targetId: 
      signalId: 
      duration: 0
      clearPreviousHighlights: 0
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: Now tryout all other substances you want to put into that body and hit
      that create button to welcome your first cafe employee!
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
