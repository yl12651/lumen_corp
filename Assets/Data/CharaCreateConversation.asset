%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5fa92c1ac281497086f905a3a552828e, type: 3}
  m_Name: CharaCreateConversation
  m_EditorClassIdentifier: Assembly-CSharp::ConversationCutsceneAsset
  title: 
  nextSceneName: CafeScene
  defaultPortrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
  lines:
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: Welcome to Lumen Corp. Before the cafe opens, we need to understand who
      will be working here.
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: You will create characters by shaping their personalities with six sliders.
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: After that, you will assign them to cafe positions and see how their choices
      affect the final conversation.
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: Let's begin!
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: 'First try moving that slider! This one adjust how strongly the subject
      is drawn to new ideas, as well as unfamiliar situations. '
    advanceMode: 1
    requiredSignalId: curiosity_slider_changed
    hideCanvasWhileWaitingForSignal: 0
    startActions:
    - actionType: 1
      targetId: curiosity_slider
      signalId: 
      duration: 0.25
      clearPreviousHighlights: 1
    endActions:
    - actionType: 3
      targetId: 
      signalId: 
      duration: 0
      clearPreviousHighlights: 0
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: Now try hitting that create button and see what we got!
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: temp
    advanceMode: 1
    requiredSignalId: create_triggered
    hideCanvasWhileWaitingForSignal: 1
    startActions:
    - actionType: 1
      targetId: create_button
      signalId: 
      duration: 0.25
      clearPreviousHighlights: 1
    endActions:
    - actionType: 3
      targetId: 
      signalId: 
      duration: 0
      clearPreviousHighlights: 0
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: "Do they look cute to you? Please let it be yes ( \u2022\u0301\u032F ^
      \u2022\u0300\u032F) Add them to your inventory or click recreate to try some
      adjustments!"
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 1
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: 
    advanceMode: 1
    requiredSignalId: add_triggered
    hideCanvasWhileWaitingForSignal: 1
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: You just added your first character! ICYMI, you can view all you've got
      here.
    advanceMode: 1
    requiredSignalId: bag_triggered
    hideCanvasWhileWaitingForSignal: 0
    startActions:
    - actionType: 1
      targetId: bag_button
      signalId: 
      duration: 0.25
      clearPreviousHighlights: 1
    endActions:
    - actionType: 3
      targetId: 
      signalId: 
      duration: 0
      clearPreviousHighlights: 0
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: Yay! Here she is! Do remember you can bring up to 8 staff with you at once.
      When you are ready creating at least 6 characters, let's get ready to open
      up the cafe!
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: 
    advanceMode: 1
    requiredSignalId: not_enough_triggered
    hideCanvasWhileWaitingForSignal: 1
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: Hey that is not enough staff to run our cafe :( Please please let's at
      least bring 6 of them cuties!
    advanceMode: 0
    requiredSignalId: 
    hideCanvasWhileWaitingForSignal: 0
    startActions: []
    endActions: []
  - speakerName: Clothos
    portrait: {fileID: 21300000, guid: 90de8a25fb68de34eb030b5fda298349, type: 3}
    text: EOF
    advanceMode: 1
    requiredSignalId: EOF
    hideCanvasWhileWaitingForSignal: 1
    startActions: []
    endActions: []
