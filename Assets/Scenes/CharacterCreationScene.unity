  lockedCatalogSprite: {fileID: 21300000, guid: 96ab2a372af6d8e40b74e4046a5422a5, type: 3}
  catalogCharacters:
  - id: Cor
    displayName: Subject-C
    lockedHint: Aim for balance with low instability and higher humility/discipline.
      Not extreme, but steady and well-regulated.
  - id: Emo
    displayName: Subject-E
    lockedHint: Push empathy and instability very high. Keep the rest moderate, as
      if emotion overwhelms control.
  - id: Inw
    displayName: Subject-I
    lockedHint: Lower drive, keep discipline and humility higher, and avoid extremes
      elsewhere. Quiet stability with little outward push.
  - id: Log
    displayName: Subject-L
    lockedHint: Max discipline, raise curiosity, and keep instability very low. Calm,
      ordered, analytical traits are the key.
  - id: Rep
    displayName: Subject-R
    lockedHint: Favor high drive and instability, with very low discipline, empathy,
      and humility. This one comes from impulse over restraint.
  - id: Soc
    displayName: Subject-S
    lockedHint: Raise drive and empathy, keep instability low. A socially active
      setup with strong outward energy points here.
  characterSprites:
  - id: Cor
    sprite: {fileID: 21300000, guid: 7457c502a8eb5d84cb88a8cde7ffc1ef, type: 3}
  - id: Emo
