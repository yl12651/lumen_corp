{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "c99acc81bbb24687b6fdfe84a6af3d16",
    "m_Title": "",
    "m_Content": "Hi so if the inputs to this node look out of order to you, it's literally not my fault. Go check out the subgraph, they are meant to be in that order. Unity say they have fixed this bug in every update, but that's a big old lie - it's been present in every version I've used and it hurts my eyes and my soul every time.",
    "m_TextSize": 0,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": -402.0,
        "y": 8.0,
        "width": 200.0,
